# Copy to .env for local `netlify dev`. Never commit the real .env file.
# In production, set this in the Netlify dashboard: Site settings → Environment variables.
NANOBANANA_API_KEY=

# Optional: require this passphrase (sent as the X-Site-Key header) before
# /api/stage will run. Leave blank to allow anyone with the site URL to stage.
SITE_ACCESS_KEY=
