# Copy to .env for local `vercel dev`. Never commit the real .env file.
# In production, set this in the Vercel dashboard: Project → Settings → Environment Variables.

# OpenAI API key from platform.openai.com — used for AI photo-staging (gpt-image-1 image edits).
OPENAI_API_KEY=

# Optional: override the image model (defaults to gpt-image-1).
OPENAI_IMAGE_MODEL=

# Optional: low | medium | high | auto (defaults to medium) — controls cost/quality tradeoff.
OPENAI_IMAGE_QUALITY=
