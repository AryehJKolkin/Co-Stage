# Copy to .env for local `vercel dev`. Never commit the real .env file.
# In production, set this in the Vercel dashboard: Project → Settings → Environment Variables.

# Gemini API key from aistudio.google.com (Get API Key) — used for AI staging.
GEMINI_API_KEY=

# Optional: override the Gemini image model (defaults to gemini-3-pro-image-preview).
GEMINI_MODEL=
